{
  "manifest_version": 3,
  "name": "BiliBlock · B站个人屏蔽助手",
  "version": "0.1.0",
  "description": "个人主动屏蔽B站指定UID的所有内容（评论/投稿/动态/弹幕/推荐/搜索），不占用官方拉黑名额；支持关键词与免费大模型自动筛选评论。",
  "permissions": ["storage", "contextMenus", "offscreen"],
  "host_permissions": ["*://*.bilibili.com/*", "*://*.hdslb.com/*"],
  "optional_host_permissions": ["*://*/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "BiliBlock · B站个人屏蔽助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "ui/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": [
        "src/common/crc32.js",
        "src/common/filter-core.js",
        "src/common/endpoints.js",
        "src/inject/dmproto.js",
        "src/inject/inject.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": [
        "src/common/filter-core-iso.js",
        "src/common/defaults.js",
        "src/common/store.js",
        "src/content/scanner.js",
        "src/content/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "ISOLATED"
    }
  ]
}
